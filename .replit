modules = ["python-3.12", "web", "nodejs-20"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["gh"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm install && npx expo start --web --port 5000 --non-interactive"
waitForPort = 5000

[deployment]
deploymentTarget = "autoscale"
publicDir = "."
run = ["npx", "expo", "start", "--web", "--port", "5000", "--no-dev"]

[[ports]]
localPort = 5001
externalPort = 80
